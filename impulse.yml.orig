general:
  week_start: Sun
  workday_start: "10:00"
  timezone: Europe/Moscow

incident:  # incidents behavior options
  notifications:  # incident notifications settings
    # assignment: True  # enable/disable notifications about incident assignment changes
    # new_firing: True  # notification about new firing instances
    # partial_resolved: True  # nofitication about some resolved instances
    status_update: True  # notification about incident status updates
  timeouts:  # incident status timeouts (https://docs.impulse.bot/stable/concepts/#lifecycle)
    firing: 10m  # after this time, incident status changes from 'firing' to 'unknown' if no alerts appear
    unknown: 10m  # after this time, incident status changes from 'unknown' to 'closed' if no alerts appear
    resolved: 1h  # after this time, incident status changes from 'resolved' to 'closed' if no alerts appear
    closed: 5m  # after this time, incident will be removed

