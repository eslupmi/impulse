webhooks:
  test:
    url: http://webhook.impulse.bot/
    data:
      instances: "{{ incident.payload.alerts | map(attribute='labels.instance') | unique | join(', ') }}"
  instatus:
    url: https://api.instatus.com/v3/integrations/prometheus/cmh1lqgrn00f9p69ifz5lzfi2
    json: '{{ payload }}'
  non_existing_domain: {url: http://webhook3.impulse.bot/, data: {some_data: 'hello'}}
  ok: {url: http://webhook.impulse.bot/ok, data: {some_data: 'hello'}}
  status_code_404: {url: http://webhook.impulse.bot/404, data: {some_data: 'hello'}}

ui:  # user interface configuration (https://docs.impulse.bot/stable/ui/)
  colors:  # Color scheme for different values (https://docs.impulse.bot/stable/config_file/#uicolors)
    severity:
      critical: "#FF0000"
      warning: "#FFA500"
      info: "#00FF00"
  columns:  # defines the columns that are used in the user interface (https://docs.impulse.bot/stable/config_file/#uicolumns)
    - name: status  # unique identifier for the column, used for filtering and sorting
      header: Status  # display name shown in the column header
      visible: False  # whether the column is visible by default in the UI. Invisible columns can be used in search fields
      value: incident.status  # data source variable (https://docs.impulse.bot/stable/config_file/#uicolumnsvalue)
    - name: created
      header: Created
      type: datetime  # column data type that determines how the value is rendered (https://docs.impulse.bot/stable/config_file/#uicolumnstype)
      value: incident.created
    - name: alertname
      header: Alertname
      type: link
      url: incident.link  # variable containing the required link (used with type: link)
      value: payload.commonLabels.alertname
    - name: service
      header: Service
      value: payload.commonLabels.service
    - name: severity
      header: Severity
      value: payload.commonLabels.severity
    - name: assigned
      header: Assigned To
      value: incident.assigned_fullname
  filters:  # defines the default filters applied in the user interface (https://docs.impulse.bot/stable/config_file/#uifilters)
    - severity=~"warning|critical"
  sorting:  # the default column sorting order (https://docs.impulse.bot/stable/config_file/#uisorting)
    - severity: desc
      order: ["info", "warning", "critical"]
    - created: desc
