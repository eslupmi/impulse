# Documentation here: https://docs.impulse.bot/stable/envs/

# DATA_PATH=./data  # Path to data directory
# CHAIN_PROVIDER_DAYS_TO_SYNC=7  # How many days will be synced (for https://docs.impulse.bot/stable/config_file/#cloud-chain)
# CHAIN_PROVIDER_MAX_EVENTS=10  # Maximum events which will be synced (for https://docs.impulse.bot/stable/config_file/#cloud-chain)
# CHAIN_PROVIDER_SYNC_INTERVAL_SECONDS=60  # Sync interval, seconds (for https://docs.impulse.bot/stable/config_file/#cloud-chain)
# CONFIG_PATH=./  # Path to `impulse.yml` directory
# GOOGLE_SERVICE_ACCOUNT_FILE=.key.json  # Path to Google service account file (for https://docs.impulse.bot/stable/config_file/#cloud-chain)
# LOG_LEVEL=INFO  # Log level (https://github.com/DiTsi/impulse/blob/develop/app/logging.py#L15)
CORS_ALLOWED_ORIGINS=<your_domain>  # Сomma-separated list of origins<br> allowed to make cross-origin<br> requests to the server |  | for UI |
SLACK_BOT_USER_OAUTH_TOKEN=<your_slack_bot_user_auth_token>  # Slack 'Bot User OAuth Token' (Slack)
SLACK_VERIFICATION_TOKEN=<your_slack_bot_verification_token>  # Slack 'Verification Token' (Slack)
# MATTERMOST_ACCESS_TOKEN=<your_mattermost_bot_access_token>  # Mattermost 'Access Token' (Mattermost)
# TELEGRAM_BOT_TOKEN=<your_tg_bot_token>  # Telegram 'Bot Token' (Telegram)
