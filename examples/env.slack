# DATA_PATH=./data  # Path to data directory
# CHAIN_PROVIDER_DAYS_TO_SYNC=7  # How many days will be synced
# CHAIN_PROVIDER_MAX_EVENTS=10  # Maximum events which will be synced
# CHAIN_PROVIDER_SYNC_INTERVAL_SECONDS=60  # Sync interval, seconds
# CONFIG_PATH=./  # Path to `impulse.yml` directory
# GOOGLE_SERVICE_ACCOUNT_FILE=.key.json  # Path to Google service account file
# HTTP_PREFIX  # HTTP prefix for reverse proxy deployments
# LOG_LEVEL=INFO  # Log level
CORS_ALLOWED_ORIGINS=<impulse_domains>  # Сomma-separated list of origins allowed to make cross-origin requests to the server
SLACK_BOT_USER_OAUTH_TOKEN=<your_slack_bot_user_auth_token>  # Slack 'Bot User OAuth Token' (Slack)
SLACK_VERIFICATION_TOKEN=<your_slack_bot_verification_token>  # Slack 'Verification Token' (Slack)
# MATTERMOST_ACCESS_TOKEN=<your_mattermost_bot_access_token>  # Mattermost 'Access Token' (Mattermost)
# TELEGRAM_BOT_TOKEN=<your_tg_bot_token>  # Telegram 'Bot Token' (Telegram)
# JIRA_API_TOKEN=<jira_api_token>  # Jira API token for Basic Auth
# JIRA_BASE_URL=<jira_base_url>  # Jira base URL (e.g., 'https://your-domain.atlassian.net')
# JIRA_USER_EMAIL=<jira_user_email>  # Jira user email for Basic Auth
